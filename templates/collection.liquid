<div class="section container">
    <div class="section-header">
      <h1 class="section-title">{{ collection.title }}</h1>
      <span>{{ collection.products_count }} Produkte</span>
    </div>
  {%- if collection.description != blank -%}
      <div class="collection-desc">{{ collection.description }}</div>
  {%- endif -%}
    <div class="product-grid">
  {%- for product in collection.products -%}
        <article class="product-card" itemscope itemtype="https://schema.org/Product">
          <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
            <div class="product-image-wrap">
  {%- if product.featured_image -%}
  {{ product.featured_image | image_url: width: 480 | image_tag:
                alt: product.featured_image.alt | escape,
                  loading: 'lazy', width: 480, height: 600, itemprop: 'image'
  }}
{%- endif -%}
{%- if product.compare_at_price > product.price -%}
              <span class="sale-badge">Sale</span>
  {%- endif -%}
          </div>
          </a>
          <div class="product-info">
            <h2 class="product-name" itemprop="name">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h2>
            <div class="product-pricing">
  {%- if product.compare_at_price > product.price -%}
              <span class="price-sale">{{ product.price | money }}</span>
                <span class="price-original">{{ product.compare_at_price | money }}</span>
  {%- else -%}
              <span class="price-sale">{{ product.price | money }}</span>
  {%- endif -%}
          </div>
  {%- if product.available -%}
            <button class="btn-add-to-cart" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                In den Warenkorb
            </button>
{%- else -%}
            <button class="btn-add-to-cart" disabled>Ausverkauft</button>
{%- endif -%}
        </div>
      </article>
{%- else -%}
      <p>Keine Produkte in dieser Kollektion.</p>
  {%- endfor -%}
  </div>
  {%- if paginate.pages > 1 -%}
{% paginate collection.products by 24 %}
      <div class="pagination">{{ paginate | default_pagination }}</div>
  {% endpaginate %}
  {%- endif -%}
</div>
