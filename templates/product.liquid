<div class="product-page container section">
  <div class="product-page-grid">
      <div class="product-page-images">
            {%- for image in product.images -%}
                    {{ image | image_url: width: 800 | image_tag:
                              alt: image.alt | escape,
                                        loading: forloop.first | iif: 'eager', 'lazy',
                                                  class: 'product-page-img',
                                                            width: 800,
                                                                      height: 1000
                                                                              }}
                                                                                    {%- endfor -%}
                                                                                        </div>
                                                                                            <div class="product-page-info">
                                                                                                  <nav class="breadcrumb" aria-label="Breadcrumb">
                                                                                                          <a href="{{ routes.root_url }}">Home</a> /
                                                                                                                  {%- if product.collections.first -%}
                                                                                                                            <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a> /
                                                                                                                                    {%- endif -%}
                                                                                                                                            <span>{{ product.title }}</span>
                                                                                                                                                  </nav>
                                                                                                                                                        <h1 class="product-page-title">{{ product.title }}</h1>
                                                                                                                                                              <div class="product-pricing product-page-price">
                                                                                                                                                                      {%- if product.compare_at_price > product.price -%}
                                                                                                                                                                                <span class="price-sale">{{ product.price | money }}</span>
                                                                                                                                                                                          <span class="price-original">{{ product.compare_at_price | money }}</span>
                                                                                                                                                                                                    <span class="sale-badge" style="position:static;margin-left:8px;">Sale</span>
                                                                                                                                                                                                            {%- else -%}
                                                                                                                                                                                                                      <span class="price-sale">{{ product.price | money }}</span>
                                                                                                                                                                                                                              {%- endif -%}
                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                          <div class="product-page-desc">{{ product.description }}</div>
                                                                                                                                                                                                                                                {%- form 'product', product, id: 'product-form' -%}
                                                                                                                                                                                                                                                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
                                                                                                                                                                                                                                                                {%- if product.has_only_default_variant == false -%}
                                                                                                                                                                                                                                                                          {%- for option in product.options_with_values -%}
                                                                                                                                                                                                                                                                                      <div class="product-option">
                                                                                                                                                                                                                                                                                                    <label class="option-label" for="option-{{ forloop.index }}">{{ option.name }}</label>
                                                                                                                                                                                                                                                                                                                  <select id="option-{{ forloop.index }}" name="options[{{ option.name | escape }}]" class="option-select">
                                                                                                                                                                                                                                                                                                                                  {%- for value in option.values -%}
                                                                                                                                                                                                                                                                                                                                                    <option value="{{ value | escape }}" {%- if option.selected_value == value -%}selected{%- endif -%}>
                                                                                                                                                                                                                                                                                                                                                                        {{ value }}
                                                                                                                                                                                                                                                                                                                                                                                          </option>
                                                                                                                                                                                                                                                                                                                                                                                                          {%- endfor -%}
                                                                                                                                                                                                                                                                                                                                                                                                                        </select>
                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                              {%- endfor -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                      {%- endif -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                              <div class="product-qty-row">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <label for="qty">Menge</label>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <input type="number" id="qty" name="quantity" value="1" min="1" class="qty-input" />
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  {%- if product.available -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <button type="submit" class="btn btn-primary product-add-btn">In den Warenkorb</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {%- else -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <button type="button" class="btn btn-primary product-add-btn" disabled>Ausverkauft</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {%- endif -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {%- endform -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <style>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-page-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-page-images{display:flex;flex-direction:column;gap:12px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-page-img{width:100%;border-radius:6px;aspect-ratio:4/5;object-fit:cover}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-page-title{font-family:var(--font-display);font-size:clamp(1.8rem,3vw,2.4rem);font-weight:900;text-transform:uppercase;margin-bottom:16px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-page-price{margin-bottom:20px;font-size:1.2rem}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-page-desc{color:#5A4E42;line-height:1.8;margin-bottom:24px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .breadcrumb{font-size:0.78rem;color:#999;margin-bottom:12px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .breadcrumb a:hover{color:var(--color-sand)}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-option{margin-bottom:16px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .option-label{display:block;font-size:0.8rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:6px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .option-select{width:100%;padding:10px 14px;border:1px solid #D0C9C0;border-radius:var(--radius);font-size:0.9rem;background:var(--color-white);font-family:var(--font-body)}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-qty-row{display:flex;align-items:center;gap:16px;margin-bottom:20px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-qty-row label{font-size:0.8rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .qty-input{width:70px;padding:10px;border:1px solid #D0C9C0;border-radius:var(--radius);text-align:center;font-size:0.9rem}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .product-add-btn{width:100%;justify-content:center;padding:16px}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  @media(max-width:768px){.product-page-grid{grid-template-columns:1fr}}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </style>
