<section class="section {% if section.settings.bg_alt %}section-alt{% endif %}">
  <div class="container">
      {%- if section.settings.title != blank -%}
            <div class="section-header">
                    <h2 class="section-title">{{ section.settings.title }}</h2>
                            {%- if section.settings.collection != blank -%}
                                      <a href="{{ section.settings.collection.url }}" class="section-link">Alle ansehen</a>
                                              {%- endif -%}
                                                    </div>
                                                        {%- endif -%}

                                                            {%- assign products_to_show = section.settings.collection.products | default: collections.all.products -%}
                                                                <div class="product-grid">
                                                                      {%- for product in products_to_show limit: section.settings.products_count -%}
                                                                              <article class="product-card" itemscope itemtype="https://schema.org/Product">
                                                                                        <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                                                                                                    <div class="product-image-wrap">
                                                                                                                  {%- if product.featured_image -%}
                                                                                                                                  {{ product.featured_image | image_url: width: 480 | image_tag:
                                                                                                                                                    alt: product.featured_image.alt | escape,
                                                                                                                                                                      loading: 'lazy',
                                                                                                                                                                                        width: 480,
                                                                                                                                                                                                          height: 600,
                                                                                                                                                                                                                            itemprop: 'image'
                                                                                                                                                                                                                                            }}
                                                                                                                                                                                                                                                          {%- endif -%}
                                                                                                                                                                                                                                                                        {%- if product.compare_at_price > product.price -%}
                                                                                                                                                                                                                                                                                        <span class="sale-badge">Sale</span>
                                                                                                                                                                                                                                                                                                      {%- endif -%}
                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                            </a>
                                                                                                                                                                                                                                                                                                                                      <div class="product-info">
                                                                                                                                                                                                                                                                                                                                                  <h3 class="product-name" itemprop="name">
                                                                                                                                                                                                                                                                                                                                                                <a href="{{ product.url }}">{{ product.title }}</a>
                                                                                                                                                                                                                                                                                                                                                                            </h3>
                                                                                                                                                                                                                                                                                                                                                                                        <div class="product-pricing" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                                                                                                                                                                                                                                                                                                                                                                                                      <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}" />
                                                                                                                                                                                                                                                                                                                                                                                                                    <meta itemprop="price" content="{{ product.price | divided_by: 100.0 }}" />
                                                                                                                                                                                                                                                                                                                                                                                                                                  {%- if product.compare_at_price > product.price -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                  <span class="price-sale">{{ product.price | money }}</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <span class="price-original">{{ product.compare_at_price | money }}</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {%- else -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <span class="price-sale">{{ product.price | money }}</span>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              {%- endif -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {%- if product.available -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <button
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    class="btn-add-to-cart"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    aria-label="{{ product.title | escape }} in den Warenkorb"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  >
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  In den Warenkorb
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {%- else -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <button class="btn-add-to-cart" disabled>Ausverkauft</button>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {%- endif -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </article>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              {%- else -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <p>Keine Produkte gefunden.</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {%- endfor -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </section>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  {% schema %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "name": "Featured Products",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "settings": [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          { "type": "text", "id": "title", "label": "Titel", "default": "Unsere Produkte" },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              { "type": "collection", "id": "collection", "label": "Kollektion" },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  { "type": "range", "id": "products_count", "min": 2, "max": 12, "step": 1, "label": "Anzahl Produkte", "default": 4 },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      { "type": "checkbox", "id": "bg_alt", "label": "Alternativer Hintergrund", "default": false }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ],
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          "presets": [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              { "name": "Featured Products", "settings": { "title": "Unsere Produkte" } }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {% endschema %}
